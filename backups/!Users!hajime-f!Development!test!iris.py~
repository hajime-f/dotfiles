import numpy as np
from sklearn.model_selection import train_test_split


def func_1(input_x):
    """Schaal関数の実装"""

    output_y = []

    for x_i in input_x:

        tmp = np.sqrt(np.power(x_i[0], 2) + np.power(x_i[1], 2))
        y_i = np.sin(tmp) / tmp

        output_y.append(y_i)

    return np.array(output_y)


N = 2
T = 100
data_x = 20 * np.random.rand(T, N) - 10
data_y = func_1(data_x)

xtrain, xtest, ytrain, ytest = train_test_split(data_x, data_y, test_size=0.1)
